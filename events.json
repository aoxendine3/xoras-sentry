      {"cmd": "dd if=/dev/urandom of=./tmp/stress/xoras_entropy.bin bs=1024 count=512 status=none", "recoverable": true, "timeout": 10},
      {"cmd": "node -e \"const c=require('crypto');const h=c.createHash('sha256');h.update(c.randomBytes(1e6));console.log('hash:',h.digest('hex'))\"", "recoverable": true, "timeout": 10},
      {"cmd": "node -e \"setTimeout(() => console.log('XORAS fast check'), 100)\"", "recoverable": true, "timeout": 8},
