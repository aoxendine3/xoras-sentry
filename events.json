{
  "maxRetries": 3,
  "baseDelayMs": 800,
  "failureThreshold": 0.25,
  "maxConcurrentAgents": 4,
  "eventsPerAgent": 10,
  "globalSetup": ["mkdir -p ./tmp/stress"],
  "globalTeardown": ["rm -rf ./tmp/stress"],
  "agents": {
    "XORAS": [
      {"cmd": "node -e \"const b=Buffer.alloc(10*1024*1024,'x');require('fs').writeFileSync('./tmp/stress/xoras_bulk.bin',b)\"", "recoverable": true, "timeout": 10},
