      {"cmd": "node -e \"require('fs').writeFileSync('./tmp/stress/vance_msg_'+Date.now()+'.json',JSON.stringify({from:'Vance',to:'LEX CORE',payload:'ping'}))\"", "recoverable": true, "timeout": 5},
