      {"cmd": "node -e \"const fs=require('fs');fs.writeFileSync('./tmp/stress/aurelius_state.json',JSON.stringify({epoch:Date.now(),seq:1}));const r=JSON.parse(fs.readFileSync('./tmp/stress/aurelius_state.json'));console.log('state read:',r.seq)\"", "recoverable": true, "timeout": 10},
