      {"cmd": "node -e \"process.exit(1)\"", "recoverable": false, "timeout": 5, "expectedCode": 1},
      {"cmd": "node -e \"const fs=require('fs');for(let i=0;i<100;i++)try{fs.unlinkSync('./tmp/stress/xoras_churn_'+i+'.tmp')}catch(e){};console.log('cleanup done')\"", "recoverable": true, "timeout": 10},
      {"cmd": "ls -la ./tmp/stress/xoras_* 2>/dev/null || echo 'XORAS workspace clean'", "recoverable": true, "timeout": 5}
    ],
    "Nova": [
