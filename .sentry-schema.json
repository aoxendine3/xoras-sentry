{
  "schemas": {
    "STRIPE_SECRET_KEY": {
      "prefix": "sk_test_",
      "minLength": 32,
      "description": "Stripe Live Secret Key (Production Only)"
    },
    "AWS_ACCESS_KEY_ID": {
      "regex": "^AKIA[A-Z0-9]{16}$",
      "description": "AWS IAM Access Key"
    },
    "PORT": {
      "regex": "^[0-9]{4,5}$",
      "description": "Service Port Number"
    },
    "XORAS_PRINCIPAL_SECRET": {
      "description": "Secret used to sign the audit payloads using HMAC-SHA256"
    },
    "GITHUB_REPOSITORY": {
      "description": "Standard GitHub Action repository indicator"
    }
  },
  "customPatterns": [
    {
      "name": "XORAS_INTERNAL_KEY",
      "regex": "xor_[a-zA-Z0-9]{32}",
      "description": "Internal proprietary secret format"
    }
  ]
}
