{
  "name": "xoras-sentry-monorepo",
  "version": "1.2.2",
  "private": true,
  "description": "Professional Integrity Auditing Suite (Monorepo)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "node packages/core/tests/sandbox.test.cjs && node tests/audit.test.cjs && node tests/infrastructure_gate.test.cjs && node tests/revenue.test.cjs && node tests/spectrum.test.cjs",
    "audit": "npm run audit --workspace=packages/cli",
    "clean": "npm run audit --workspace=packages/cli -- --janitor",
    "ui": "npm run start --workspace=packages/ui"
  },
  "author": "Anthony Oxendine",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "stripe": "^22.1.1"
  }
}
