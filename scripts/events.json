{
  "maxRetries": 3,
  "baseDelayMs": 800,
  "failureThreshold": 0.25,
  "maxConcurrentAgents": 4,
  "eventsPerAgent": 15,
  "globalSetup": ["mkdir -p ./tmp/stress"],
  "globalTeardown": ["rm -rf ./tmp/stress"],
  "agents": {
    "Nova": [
      {"cmd": "npm ci", "recoverable": true, "timeout": 30},
      {"cmd": "npm run lint", "recoverable": true, "timeout": 15},
      {"cmd": "npm test", "recoverable": true, "timeout": 20},
      {"cmd": "node -e \"while(true){}\" & sleep 3 && kill $!", "recoverable": true, "timeout": 10},
      {"cmd": "node -e \"require('fs').writeFileSync('./tmp/stress/nova_fuzz_'+Date.now()+'.tmp', 'x'.repeat(3e6))\"", "recoverable": true, "timeout": 10},
      {"cmd": "echo \"TMP_VAR_$(date +%s)=test\" >> .env.test", "recoverable": true, "timeout": 5},
      {"cmd": "npm outdated", "recoverable": true, "timeout": 15},
      {"cmd": "npm run build", "recoverable": true, "timeout": 25},
      {"cmd": "node -e \"process.exit(1)\"", "recoverable": false, "timeout": 5},
      {"cmd": "curl -s --max-time 10 https://httpbin.org/delay/8", "recoverable": true, "timeout": 15},
      {"cmd": "dd if=/dev/zero of=./tmp/stress/bigfile bs=1M count=50 status=none", "recoverable": true, "timeout": 15},
      {"cmd": "npm audit", "recoverable": true, "timeout": 20},
      {"cmd": "node -e \"let a=[];for(let i=0;i<5e5;i++)a.push(Buffer.alloc(1e5))\"", "recoverable": true, "timeout": 10},
      {"cmd": "sh -c \"exit $((RANDOM%2))\"", "recoverable": true, "timeout": 5},
      {"cmd": "ls -la ./tmp/stress", "recoverable": true, "timeout": 5}
    ],
